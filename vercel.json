{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python",
      "config": {
        "includeFiles": [
          "api/pitch_coach_xgb.json",
          "feature_utils.py",
          "gemini_utils.py"
        ]
      }
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.py" },
    { "src": "/(.*)",     "dest": "/public/$1"    }
  ],
  "functions": {
    "api/index.py": {
      "maxDuration": 60
    }
  }
}
